---
import '../styles/tokens.css';
import '../styles/admin.css';
const { title = 'Dashboard', active = 'dashboard' } = Astro.props;
// In production the real gate is Cloudflare Access (edge). The local passcode overlay
// is only for dev/preview, so we never double-prompt behind Access.
const isProd = import.meta.env.PROD;
const items = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin/' },
  { id: 'content', label: 'Content', href: '/admin/#content' },
  { id: 'theme', label: 'Theme Studio', href: '/admin/theme/' },
  { id: 'profile', label: 'Profile & photo', href: '/admin/profile/' },
];
const future = ['Publish queue', 'Analytics', 'Comments', 'Settings'];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · Studio · Hardeep Anand</title>
    <script is:inline>
      // Shared theme engine: base theme + custom overrides + avatar, before paint.
      (function () {
        try {
          document.documentElement.dataset.theme = localStorage.getItem('ha-theme') || 'operator';
          var c = localStorage.getItem('ha-custom');
          if (c) { var o = JSON.parse(c); for (var k in o) document.documentElement.style.setProperty(k, o[k]); }
        } catch (e) { document.documentElement.dataset.theme = 'operator'; }
      })();
    </script>
    <style>
      .admin-gate { position: fixed; inset: 0; z-index: 100000; display: flex; align-items: center; justify-content: center; padding: 24px; background: radial-gradient(130% 130% at 50% 0%, #18223a, #0B0E14 68%); }
      .gate-card { width: min(420px, 92vw); background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 36px 32px; text-align: center; box-shadow: 0 30px 90px rgba(0,0,0,.55); }
      .gate-brand { font-family: var(--font-display); font-weight: 600; font-size: 22px; color: var(--text); margin-bottom: 24px; }
      .gate-brand b { color: var(--accent); }
      .gate-h { font-family: var(--font-display); font-weight: 600; font-size: 27px; letter-spacing: -.01em; color: var(--text); margin-bottom: 8px; }
      .gate-sub { color: var(--text-dim); font-size: 14px; margin-bottom: 22px; font-family: var(--font-ui); line-height: 1.5; }
      .gate-card input { width: 100%; background: var(--bg); border: 1px solid var(--line); border-radius: 9px; padding: 14px; color: var(--text); font-size: 16px; font-family: var(--font-ui); margin-bottom: 12px; text-align: center; letter-spacing: .12em; }
      .gate-card input::placeholder { letter-spacing: .04em; }
      .gate-card input:focus { outline: none; border-color: var(--accent); }
      .gate-card button { width: 100%; background: var(--accent); color: var(--on-accent); border: none; border-radius: 9px; padding: 14px; font-weight: 600; font-size: 15px; font-family: var(--font-ui); cursor: pointer; }
      .gate-card button:hover { background: color-mix(in srgb, var(--accent) 88%, #fff); }
      .gate-note { color: var(--text-dim); font-size: 12px; margin-top: 18px; font-family: var(--font-ui); line-height: 1.5; opacity: .85; }
      .gate-err { color: #ff7a7a; font-size: 13px; margin-top: 10px; min-height: 16px; font-family: var(--font-ui); }
      .admin-signout { background: none; border: none; color: var(--text-dim); font-family: var(--font-ui); font-size: 12px; cursor: pointer; padding: 0; margin-top: 8px; text-decoration: underline; }
      .admin-signout:hover { color: var(--accent); }
    </style>
  </head>
  <body>
    {!isProd && (
    <div class="admin-gate" id="adminGate">
      <form class="gate-card" id="gateForm">
        <div class="gate-brand">Hardeep<b>.</b>Anand</div>
        <div class="gate-h">Studio sign in</div>
        <p class="gate-sub" id="gateSub">Enter your studio passcode.</p>
        <input type="password" id="gateCode" placeholder="Passcode" autocomplete="off" autofocus />
        <button type="submit">Enter the Studio</button>
        <p class="gate-err" id="gateErr"></p>
        <p class="gate-note">Local preview gate. On hardeepanand.com this screen is replaced by Cloudflare Access (your email, no password to manage).</p>
      </form>
    </div>
    )}
    <div class="admin">
      <aside class="admin-side">
        <div class="admin-me">
          <div class="admin-avatar" id="adminAvatar">HA</div>
          <div>
            <div class="nm">Hardeep Anand</div>
            <div class="ro">P.E. · OWNER</div>
          </div>
        </div>
        <nav class="admin-nav">
          {items.map((it) => (
            <a href={it.href} class={active === it.id ? 'on' : ''}><span class="ic"></span>{it.label}</a>
          ))}
          {future.map((f) => (
            <a class="muted"><span class="ic"></span>{f}</a>
          ))}
        </nav>
        <div class="foot">
          hardeepanand.com<br />gate with Cloudflare Access before deploy
          <br /><button class="admin-signout" id="adminSignout">Sign out</button>
        </div>
      </aside>
      <main class="admin-main">
        <slot />
      </main>
    </div>
    {!isProd && (
    <script is:inline>
      // Local studio gate. Real auth on production is Cloudflare Access; this is the
      // preview stand-in: set a passcode on first use, then it is required per session.
      (function () {
        var CODE = 'ha-admin-code', SESS = 'ha-admin-session';
        var gate = document.getElementById('adminGate');
        function unlock() { if (gate) gate.parentNode.removeChild(gate); }
        try { if (sessionStorage.getItem(SESS) === '1') { unlock(); return; } } catch (e) { unlock(); return; }
        var sub = document.getElementById('gateSub');
        var err = document.getElementById('gateErr');
        var stored = null; try { stored = localStorage.getItem(CODE); } catch (e) {}
        if (!stored && sub) sub.textContent = 'First time here. Set a studio passcode (remembered on this device).';
        var f = document.getElementById('gateForm');
        if (f) f.addEventListener('submit', function (ev) {
          ev.preventDefault();
          var v = (document.getElementById('gateCode').value || '').trim();
          if (!v) { if (err) err.textContent = 'Enter a passcode.'; return; }
          try {
            if (!stored) { localStorage.setItem(CODE, v); sessionStorage.setItem(SESS, '1'); unlock(); return; }
            if (v === stored) { sessionStorage.setItem(SESS, '1'); unlock(); return; }
            if (err) err.textContent = 'Wrong passcode. Try again.';
          } catch (e) { sessionStorage.setItem(SESS, '1'); unlock(); }
        });
      })();
    </script>
    )}
    <script is:inline>
      (function () {
        try {
          var p = localStorage.getItem('ha-photo');
          var a = document.getElementById('adminAvatar');
          if (p && a) { a.textContent = ''; a.style.backgroundImage = 'url(' + p + ')'; a.style.backgroundSize = 'cover'; a.style.backgroundPosition = 'center'; }
        } catch (e) {}
        var so = document.getElementById('adminSignout');
        if (so) so.onclick = function () { try { sessionStorage.removeItem('ha-admin-session'); } catch (e) {} location.reload(); };
      })();
    </script>
  </body>
</html>
